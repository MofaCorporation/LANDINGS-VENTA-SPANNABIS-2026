DB_HOST=db
DB_NAME=ecommerce
DB_USER=app
DB_PASS=changeme

# Sandbox comercio de pruebas Redsys (999008881). Si REDSYS_SECRET_KEY está vacío, se usa la clave SHA-256 de ejemplo del manual.
REDSYS_MERCHANT_CODE=999008881
REDSYS_TERMINAL=001
REDSYS_SECRET_KEY=
REDSYS_SANDBOX=true

APP_ENV=development
# URL pública del sitio (incluye subruta si aplica, sin barra final)
BASE_URL=http://localhost:8080/drops
# Segmento de ruta bajo el dominio (sin slashes). Vacío = sitio en la raíz del vhost.
BASE_PATH=drops
APP_DEBUG=false
